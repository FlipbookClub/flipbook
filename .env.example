# Public client-side keys (safe to expose in app bundle).
# Copy this file to .env.local and fill in real values; .env.local is gitignored.

# Convex (TASK-003): set after `npx convex dev` creates the project.
EXPO_PUBLIC_CONVEX_URL=

# Clerk (TASK-004): publishable key from clerk.com dashboard.
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=

# RevenueCat (Phase 6 / TASK-066): public SDK keys per platform.
EXPO_PUBLIC_REVENUECAT_API_KEY_IOS=
EXPO_PUBLIC_REVENUECAT_API_KEY_ANDROID=

# PostHog analytics (TASK-091): project API key. Leave blank to keep analytics
# as a no-op. To enable: install posthog-react-native, set this, uncomment the
# PostHog backend in src/lib/analytics.ts, and rebuild the dev client.
EXPO_PUBLIC_POSTHOG_KEY=
EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
