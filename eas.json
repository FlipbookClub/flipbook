{
  "cli": {
    "version": ">= 19.0.5",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": true
      }
    },
    "preview": {
      "distribution": "store",
      "channel": "preview",
      "environment": "preview",
      "autoIncrement": true
    },
    "production": {
      "autoIncrement": true,
      "channel": "production",
      "environment": "production"
    }
  },
  "submit": {
    "preview": {
      "ios": {
        "ascAppId": "6778644424"
      },
      "android": {
        "track": "alpha"
      }
    },
    "production": {
      "ios": {
        "ascAppId": "6778644424"
      }
    }
  }
}
