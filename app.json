{
  "expo": {
    "name": "Flipbook",
    "slug": "flipbook",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "flipbook",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#f7f3e3"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.flipbook.club"
    },
    "android": {
      "package": "com.flipbook.club",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#f7f3e3"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            { "scheme": "flipbook" },
            { "scheme": "https", "host": "flipbook.app", "pathPrefix": "/join" }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      "expo-secure-store",
      "expo-web-browser",
      "expo-document-picker",
      "@config-plugins/react-native-pdf",
      "@config-plugins/react-native-blob-util"
    ],
    "extra": {
      "eas": {
        "projectId": "81dc61a2-b202-456d-afc6-a974bce1254f"
      }
    }
  }
}
